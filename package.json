{
  "name": "@georgeal78/qbittorrent-desktop",
  "version": "1.0.30",
  "description": "qBittorrent Desktop Client for Windows 11",
  "main": "main.js",
  "author": "qBittorrent Desktop",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/GeorgeAL78/qbittorrent-desktop.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64",
    "update-components": "node scripts/update-components.js",
    "version": "node scripts/update-components.js && git add README.md"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "overrides": {
    "js-yaml": "^4.3.0"
  },
  "build": {
    "appId": "com.qbittorrent.desktop",
    "productName": "qBittorrent Desktop",
    "publish": {
      "provider": "github",
      "owner": "GeorgeAL78",
      "repo": "qbittorrent-desktop",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "qBittorrent Desktop",
      "include": "build/installer.nsh"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "protocols": [
      {
        "name": "Magnet Link",
        "schemes": [
          "magnet"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": "torrent",
        "name": "Torrent File",
        "description": "BitTorrent Torrent File",
        "role": "Default",
        "icon": "assets/icon.ico"
      }
    ]
  }
}
